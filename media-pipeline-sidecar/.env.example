PORT=8090
HOST=0.0.0.0
LOG_LEVEL=info
INTERNAL_BEARER_TOKEN=change-me

REDIS_URL=redis://localhost:6379
REDPANDA_BROKERS=localhost:9092
ENABLE_EVENT_PUBLISH=false
OPENSEARCH_URL=http://localhost:9200
MEDIA_DATA_DIR=./data
ASSET_STORE_BACKEND=redis
ASSET_STORE_REDIS_PREFIX=media:assets

S3_ENDPOINT=https://s3.filebase.com
S3_REGION=us-east-1
S3_BUCKET=media-bucket
S3_ACCESS_KEY_ID=your_key
S3_SECRET_ACCESS_KEY=your_secret
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true
S3_ENABLE_OBJECT_TAGGING=false
CLOUDFLARE_MEDIA_DOMAIN=media.example.com
IPFS_GATEWAY_BASE=https://ipfs.filebase.io/ipfs
FILEBASE_GATEWAY_BASE=https://ipfs.filebase.io/ipfs
MEDIA_OBJECT_UPLOAD_CONCURRENCY=8

MAX_DOWNLOAD_BYTES=52428800
REQUEST_TIMEOUT_MS=20000
INGRESS_MAX_BODY_BYTES=16384
STREAM_MAX_LEN=10000
DLQ_MAX_LEN=50000
PENDING_MIN_IDLE_MS=60000
PENDING_CLAIM_BATCH_SIZE=50
TRANSIENT_OBJECT_PREFIX=transient-media
SAFE_BROWSING_API_KEY=
GOOGLE_VISION_API_KEY=
GOOGLE_VIDEO_ACCESS_TOKEN=

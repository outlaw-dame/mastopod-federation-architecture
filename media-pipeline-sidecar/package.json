{
  "name": "activitypods-media-pipeline-sidecar",
  "version": "0.1.0",
  "private": true,
  "description": "Focused media pipeline sidecar for the Mastopod federation architecture",
  "type": "module",
  "main": "src/server/queueIngress.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/server/queueIngress.ts",
    "dev": "tsx watch src/server/queueIngress.ts",
    "server:dev": "node --import tsx src/dev/runLocalStack.ts",
    "smoke:runtime": "tsx scripts/smokeRuntime.ts",
    "smoke:runtime:public": "tsx scripts/smokeRuntimePublic.ts",
    "smoke:runtime:ci": "tsx scripts/smokeRuntimeCI.ts",
    "smoke:runtime:profile": "tsx scripts/smokeRuntimeProfile.ts",
    "smoke:runtime:chaos": "tsx scripts/smokeRuntimeChaos.ts",
    "smoke:runtime:video": "tsx scripts/smokeRuntimeVideo.ts",
    "smoke:runtime:video:resilience": "tsx scripts/smokeRuntimeVideoResilience.ts",
    "smoke:runtime:video:load": "tsx scripts/smokeRuntimeVideoLoad.ts",
    "smoke:runtime:reconcile": "tsx scripts/smokeRuntimeReconcile.ts",
    "reconcile:assets": "tsx scripts/reconcileCanonicalAssets.ts",
    "worker:ingest": "tsx src/workers/ingestWorker.ts",
    "worker:fetch": "tsx src/workers/fetchWorker.ts",
    "worker:process:image": "tsx src/workers/processImageWorker.ts",
    "worker:process:video": "tsx src/workers/processVideoWorker.ts",
    "worker:rendition:video": "tsx src/workers/videoRenditionWorker.ts",
    "worker:finalize": "tsx src/workers/finalizeWorker.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.882.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "file-type": "^21.3.4",
    "kafkajs": "^2.2.4",
    "pino": "^8.19.0",
    "redis": "^4.7.0",
    "sharp": "^0.34.4",
    "undici": "^6.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}

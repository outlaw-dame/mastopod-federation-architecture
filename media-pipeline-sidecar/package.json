{
  "name": "activitypods-media-pipeline-sidecar",
  "version": "0.1.0",
  "private": true,
  "description": "Tier 3 media pipeline sidecar for the Mastopod + ActivityPods federation architecture",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.882.0",
    "@aws-sdk/lib-storage": "^3.882.0",
    "fastify": "^5.8.4",
    "file-type": "^19.6.0",
    "kafkajs": "^2.2.4",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "sharp": "^0.34.4",
    "undici": "^6.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}

# Redpanda Connect env vars
# Copy to .env.connect and adjust for your environment.
# When running under docker-compose these are merged with the base .env file.

# ── Redpanda ──────────────────────────────────────────────────────────────────
# Single broker endpoint visible inside the Docker network.
# For a multi-broker cluster list all seeds separated by newlines in compose env:
#   REDPANDA_BROKER=redpanda-0:9092
REDPANDA_BROKER=redpanda:9092

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_URL=http://opensearch:9200
# Set to "true" and provide credentials if OpenSearch security is enabled.
OPENSEARCH_AUTH_ENABLED=false
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# ── S3 / Object Storage ───────────────────────────────────────────────────────
S3_ARCHIVE_BUCKET=fedify-archive
AWS_REGION=us-east-1

# Local dev: point at LocalStack.
# Production: leave S3_ENDPOINT empty and provide real AWS credentials.
S3_ENDPOINT=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SESSION_TOKEN=

# ── Connect service ───────────────────────────────────────────────────────────
# Valid values: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# ── OpenSearch initial admin password ────────────────────────────────────────
# Required by OpenSearch >= 2.12. Only used when AUTH_ENABLED=true.
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Admin1234!

# ============================================================================
# V6 Configuration Example
# ============================================================================
# This is the canonical V6 architecture configuration.
# Copy to .env and customize for your deployment.

# ============================================================================
# Server Configuration
# ============================================================================
SIDECAR_PORT=8080
SIDECAR_HOST=0.0.0.0
SIDECAR_BASE_URL=http://localhost:8080

# ============================================================================
# ActivityPods Integration
# ============================================================================
# URL of the ActivityPods instance
ACTIVITYPODS_URL=http://localhost:3000

# Bearer token for internal API access (must have sufficient permissions)
ACTIVITYPODS_TOKEN=your-secret-token-here

# Internal API endpoints (usually derived from ACTIVITYPODS_URL)
ACTIVITYPODS_SIGNING_API_URL=http://localhost:3000/api/internal/signatures/batch
ACTIVITYPODS_INBOX_RECEIVER_URL=http://localhost:3000/api/internal/inbox/receive

# ============================================================================
# Redis Configuration
# ============================================================================
# Redis connection URL for delivery state, caching, and MRF KV
REDIS_URL=redis://localhost:6379

# Delivery state and concurrency control
MAX_CONCURRENT_PER_DOMAIN=5
IDEMPOTENCY_TTL_MS=86400000
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_PER_WINDOW=1000
ACTOR_CACHE_TTL_MS=3600000

# ============================================================================
# RedPanda Configuration (Event Logs)
# ============================================================================
# RedPanda broker addresses (comma-separated)
REDPANDA_BROKERS=localhost:9092

# Client ID for RedPanda connections
REDPANDA_CLIENT_ID=fedify-sidecar-v6

# Compression algorithm (snappy, gzip, zstd, lz4, none)
REDPANDA_COMPRESSION=zstd

# Topic bootstrap profile controls replication + min ISR policy
# development => RF1 / minISR1
# staging => RF2 / minISR1
# production => RF3 / minISR2
REDPANDA_TOPIC_BOOTSTRAP_PROFILE=development

# Retries for topic bootstrap operations (exponential backoff)
REDPANDA_TOPIC_BOOTSTRAP_RETRIES=5
REDPANDA_TOPIC_BOOTSTRAP_RETRY_BASE_MS=250

# Fail startup if required topics are missing or mis-profiled.
REDPANDA_ENFORCE_TOPIC_GOVERNANCE=true

# ============================================================================
# V6 Topic Names (Canonical)
# ============================================================================
# Local public activities from ActivityPods outbox
STREAM1_TOPIC=ap.stream1.local-public.v1

# Remote public activities (post-verification)
STREAM2_TOPIC=ap.stream2.remote-public.v1

# Combined public activity stream for indexing
FIREHOSE_TOPIC=ap.firehose.v1

# Outbound delivery readiness events
OUTBOUND_TOPIC=ap.outbound.v1

# Inbound activity events (pre-MRF)
INBOUND_TOPIC=ap.inbound.v1

# MRF rejection audit trail
MRF_REJECTED_TOPIC=ap.mrf.rejected.v1

# Tombstone events (deletes)
TOMBSTONES_TOPIC=ap.tombstones.v1

# ============================================================================
# Consumer Groups
# ============================================================================
INBOUND_CONSUMER_GROUP=fedify-inbound-v6
OUTBOUND_CONSUMER_GROUP=fedify-outbound-v6
INDEXER_CONSUMER_GROUP=fedify-indexer-v6

# ============================================================================
# Inbound Worker Configuration
# ============================================================================
ENABLE_INBOUND_WORKER=true
INBOUND_CONCURRENCY=10
REQUEST_TIMEOUT_MS=30000
USER_AGENT=Fedify-Sidecar/v6

# ============================================================================
# Outbound Worker Configuration
# ============================================================================
ENABLE_OUTBOUND_WORKER=true
OUTBOUND_CONCURRENCY=20
MAX_RETRIES=10
RETRY_DELAY_MS=60000

# ============================================================================
# MRF (Message Rejection Filter) Configuration
# ============================================================================
ENABLE_MRF=true

# Comma-separated list of blocked domains
MRF_BLOCKED_DOMAINS=

# MRF Policy Flags
MRF_POLICY_SIGNATURE_VALIDATION=true
MRF_POLICY_BLOCKED_DOMAIN=true
MRF_POLICY_SUSPICIOUS_ACTIVITY=true

# ============================================================================
# OpenSearch Configuration (Tier 3 - Optional)
# ============================================================================
ENABLE_OPENSEARCH_INDEXER=false
OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_INDEX_NAME=ap-activities
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_BULK_FLUSH_BYTES=5000000
OPENSEARCH_BULK_FLUSH_INTERVAL=5000

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_WEBFINGER=true
ENABLE_ACTOR_SERVING=true

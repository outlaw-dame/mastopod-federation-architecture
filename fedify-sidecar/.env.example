# =============================================================================
# Fedify Sidecar Configuration v3
# =============================================================================

# Server settings
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
VERSION=3.0.0

# Domain settings
DOMAIN=example.com
BASE_URL=https://example.com

# =============================================================================
# RedPanda Configuration
# Used as Fedify's message queue AND for Stream1/Stream2/Firehose
# =============================================================================
REDPANDA_BROKERS=redpanda:9092
REDPANDA_CLIENT_ID=fedify-sidecar

# Topic names
TOPIC_STREAM1=stream1-local-public
TOPIC_STREAM2=stream2-remote-public
TOPIC_FIREHOSE=firehose

# Consumer group IDs
CONSUMER_GROUP_DELIVERY=fedify-delivery
CONSUMER_GROUP_INDEXER=fedify-indexer

# =============================================================================
# ActivityPods Configuration
# =============================================================================
ACTIVITYPODS_URL=http://activitypods:3000
ACTIVITYPODS_SIGNING_API_URL=http://activitypods:3000/api/signing
ACTIVITYPODS_INTERNAL_API_KEY=your-internal-api-key

# =============================================================================
# OpenSearch Configuration
# DBMS for all public activities (Firehose storage)
# =============================================================================
OPENSEARCH_NODE=http://opensearch:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX_PREFIX=activitypods
OPENSEARCH_SSL=false
OPENSEARCH_BULK_FLUSH_BYTES=5000000
OPENSEARCH_BULK_FLUSH_INTERVAL=5000

# =============================================================================
# Delivery Settings
# =============================================================================
DELIVERY_MAX_CONCURRENT_DOMAINS=50
DELIVERY_MAX_CONCURRENT_PER_DOMAIN=5
DELIVERY_CONNECTION_POOL_SIZE=10
DELIVERY_SIGNATURE_CACHE_TTL_MS=300000
DELIVERY_MAX_RETRIES=8
REQUEST_TIMEOUT=30000

# =============================================================================
# Stream Settings
# =============================================================================
STREAMS_BATCH_SIZE=100
STREAMS_BATCH_TIMEOUT_MS=1000
STREAMS_RETENTION_MS=604800000

# =============================================================================
# Metrics Settings
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# =============================================================================
# Logging Settings
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# Domain blocking (comma-separated list)
# =============================================================================
BLOCKED_DOMAINS=

# =============================================================================
# Admin API key (generate a secure random string)
# =============================================================================
ADMIN_API_KEY=your-secure-api-key-here

# =============================================================================
# Aggregator webhook URL (for Solid Notifications)
# =============================================================================
AGGREGATOR_WEBHOOK_URL=http://localhost:3001/webhooks/solid-notifications

# =============================================================================
# Grafana (for docker-compose)
# =============================================================================
GRAFANA_PASSWORD=admin

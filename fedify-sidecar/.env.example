# =============================================================================
# Fedify Sidecar Configuration v5
# =============================================================================

# Server settings
NODE_ENV=production
PORT=8080
HOST=0.0.0.0
VERSION=5.0.0

# Domain settings
DOMAIN=example.com
BASE_URL=https://example.com

# =============================================================================
# Redis Configuration
# Used for work queues (inbound/outbound), idempotency, rate limiting, etc.
# =============================================================================
REDIS_URL=redis://redis:6379

# Queue stream keys (with ap. prefix per v5 spec)
INBOUND_STREAM_KEY=ap:queue:inbound:v1
OUTBOUND_STREAM_KEY=ap:queue:outbound:v1
# DLQ stream keys — one per job type so outbound noise can't bury inbound signal
DLQ_INBOUND_STREAM_KEY=ap:queue:dlq:inbound:v1
DLQ_OUTBOUND_STREAM_KEY=ap:queue:dlq:outbound:v1
DLQ_OUTBOX_INTENT_STREAM_KEY=ap:queue:dlq:outbox-intent:v1

# Consumer configuration
CONSUMER_GROUP=sidecar-workers
BLOCK_TIMEOUT_MS=5000
# CLAIM_IDLE_TIME_MS must be strictly greater than REQUEST_TIMEOUT_MS.
# If not, xAutoClaim can steal messages from live workers causing double-delivery.
# Default: 60000ms > 30000ms (REQUEST_TIMEOUT_MS).
CLAIM_IDLE_TIME_MS=60000
# Max entries per work stream before MAXLEN trimming kicks in.
# Mastodon (Sidekiq) uses no cap — queues grow unboundedly. 500k gives ~83 minutes
# of buffer at 100 act/s lag rate without trimming. Tune per your Redis memory budget.
MAX_STREAM_LENGTH=500000
# Max entries per DLQ stream (independent cap per type). 10k each = 30k total.
MAX_DLQ_LENGTH=10000

# =============================================================================
# RedPanda Configuration
# Used ONLY for immutable event logs (Stream1, Stream2, Firehose)
# NOT used for work queues - Redis Streams handles that
# =============================================================================
REDPANDA_BROKERS=redpanda:9092
REDPANDA_CLIENT_ID=fedify-sidecar

# Event log topic names (with ap. prefix per v5 spec)
TOPIC_STREAM1=ap.public.local.v1
TOPIC_STREAM2=ap.public.remote.v1
TOPIC_FIREHOSE=ap.public.firehose.v1

# Consumer group IDs
CONSUMER_GROUP_INDEXER=sidecar-indexer

# =============================================================================
# ActivityPods Configuration
# =============================================================================
ACTIVITYPODS_URL=http://activitypods:3000
ACTIVITYPODS_TOKEN=your-internal-api-token
# Canonical local relay actor URI used by relay benchmark Follow/signing paths
AP_RELAY_LOCAL_ACTOR_URI=http://localhost:3000/relay

# Internal signing API endpoint (per v5 spec)
# POST /api/internal/signatures/batch with { requests: SignRequest[] }
SIGNING_API_URL=http://activitypods:3000/api/internal/signatures/batch

# =============================================================================
# OpenSearch Configuration
# DBMS for all public activities (Firehose storage)
# =============================================================================
OPENSEARCH_NODE=http://opensearch:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX_PREFIX=activitypods
OPENSEARCH_SSL=false
OPENSEARCH_BULK_FLUSH_BYTES=5000000
OPENSEARCH_BULK_FLUSH_INTERVAL=5000

# =============================================================================
# Delivery Settings
# =============================================================================
OUTBOUND_CONCURRENCY=64
MAX_CONCURRENT_PER_DOMAIN=10
INBOUND_CONCURRENCY=32
REQUEST_TIMEOUT_MS=30000
USER_AGENT=Fedify-Sidecar/5.0 (ActivityPods)

# =============================================================================
# Cache Settings
# =============================================================================
# TTL for remote AP actor document cache in Redis (inbound signature verification)
ACTOR_CACHE_TTL_MS=3600000
# TTL for AT DID document Redis L2 cache (survives process restarts)
DID_DOC_CACHE_TTL_SECONDS=300

# =============================================================================
# Stream Settings
# =============================================================================
STREAMS_BATCH_SIZE=100
STREAMS_BATCH_TIMEOUT_MS=1000
STREAMS_RETENTION_MS=604800000

# =============================================================================
# Metrics Settings
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Optional benchmark post-run lag soak gate (scripts/run-benchmarks.sh)
RESET_QUEUE_STATE_BEFORE_RUN=false
ENABLE_LAG_SOAK_CHECK=false
LAG_SOAK_SAMPLES=6
LAG_SOAK_INTERVAL_SEC=10
LAG_SOAK_TARGET=1000

# Outbound not-ready defer tuning.
# Jobs are deferred and re-enqueued until OUTBOUND_NOT_READY_MAX_REQUEUES,
# then parked in outbound DLQ with reason "Deferred requeue limit exceeded: not_ready".
OUTBOUND_NOT_READY_MAX_REQUEUES=32
OUTBOUND_NOT_READY_MIN_DELAY_MS=500
OUTBOUND_NOT_READY_JITTER_MS=250

# =============================================================================
# Logging Settings
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_OUTBOUND_WORKER=true
ENABLE_INBOUND_WORKER=true
ENABLE_OPENSEARCH_INDEXER=true

# FEP-8fcf: Followers Collection Synchronization (https://codeberg.org/fediverse/fep/src/branch/main/fep/8fcf/fep-8fcf.md)
# When enabled, the sidecar will:
#   - Add Collection-Synchronization headers to outbound follower-addressed activities
#   - Process incoming Collection-Synchronization headers and reconcile stale follows
#   - Serve GET /users/:id/followers_synchronization (authenticated partial collection)
# Requires three new ActivityPods internal API endpoints to be implemented
# (see FollowersSyncActivityPodsClient.ts).  Safe to enable before those endpoints
# exist — all AP calls degrade gracefully to no-ops if they return 404/501.
# FEP-eb48: Hashtags (https://codeberg.org/fediverse/fep/src/branch/main/fep/eb48/fep-eb48.md)
# When set, browser requests to GET /tags/:tag are redirected to this base URL
# with ?tag=<name> appended (e.g. "https://example.com/search").
# When unset, /tags/:tag returns a minimal HTML page for browsers and a
# full ActivityStreams Hashtag document for AP clients.
HASHTAG_SEARCH_BASE_URL=

ENABLE_FOLLOWERS_SYNC=false

# TTL (seconds) for per-domain partial follower digest cache entries in Redis.
# Default: 300 (5 min). Lower values pick up follow/unfollow changes faster at
# the cost of more ActivityPods API calls.
FOLLOWERS_SYNC_DIGEST_TTL_SECONDS=300

# =============================================================================
# Domain blocking (comma-separated list)
# =============================================================================
BLOCKED_DOMAINS=

# =============================================================================
# Admin API key (generate a secure random string)
# =============================================================================
ADMIN_API_KEY=your-secure-api-key-here

# =============================================================================
# Grafana (for docker-compose)
# =============================================================================
GRAFANA_PASSWORD=admin

# Local profile for running fedify-sidecar on host against docker-compose services
# Copy to .env.local and tweak as needed.

NODE_ENV=development
PORT=8080
METRICS_PORT=9090
# Public hostname used for actor URIs and relay activity IDs.
# For local testing with live relay traffic, use an ngrok (or similar) domain.
DOMAIN=your-domain.example.com

# Local-safe startup profile
AT_LOCAL_FIXTURE=true
ENABLE_XRPC_SERVER=false
ENABLE_OPENSEARCH_INDEXER=true

# Required for AP relay subscriptions and Fedify runtime adapter.
ENABLE_FEDIFY_RUNTIME_INTEGRATION=true
ENABLE_OUTBOX_INTENT_WORKER=true

# Host-mapped service endpoints
ACTIVITYPODS_URL=http://localhost:3000
ACTIVITYPODS_TOKEN=local-dev-token
REDIS_URL=redis://localhost:6379
REDPANDA_BROKERS=localhost:19092
OPENSEARCH_NODE=http://localhost:9200

# Memory API AP ingress webhook — relay content forwarding (optional).
# Set to your local memory-api URL if you are running that service.
MEMORY_AP_WEBHOOK_URL=
AP_BRIDGE_SECRET=change-me-ap-secret

# Topic bootstrap profile
REDPANDA_TOPIC_BOOTSTRAP_PROFILE=development

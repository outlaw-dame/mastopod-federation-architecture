{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://activitypods.dev/schemas/provider-capabilities.v1.json",
  "title": "ProviderCapabilitiesV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "provider",
    "profiles",
    "protocols",
    "capabilities",
    "entitlements",
    "degradation",
    "events",
    "security"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "region"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active", "supported"],
      "properties": {
        "active": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["ap-core", "ap-scale", "dual-protocol-standard"]
          }
        },
        "supported": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["ap-core", "ap-scale", "dual-protocol-standard"]
          }
        }
      }
    },
    "protocols": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activitypub", "atproto"],
      "properties": {
        "activitypub": { "$ref": "#/$defs/protocolStatus" },
        "atproto": { "$ref": "#/$defs/protocolStatus" }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability" }
    },
    "entitlements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plan", "effectiveAt", "overrides"],
      "properties": {
        "plan": { "type": "string", "minLength": 1 },
        "effectiveAt": { "type": "string", "format": "date-time" },
        "overrides": {
          "type": "array",
          "items": { "$ref": "#/$defs/override" }
        }
      }
    },
    "degradation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modes"],
      "properties": {
        "modes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["when", "behavior", "contractRef"],
            "properties": {
              "when": { "type": "string", "minLength": 1 },
              "behavior": { "type": "string", "minLength": 1 },
              "contractRef": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "events": {
      "type": "object",
      "additionalProperties": false,
      "required": ["catalogVersion", "topics"],
      "properties": {
        "catalogVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "topics": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "schema", "retentionDays", "replay"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "schema": { "type": "string", "minLength": 1 },
              "retentionDays": { "type": "integer", "minimum": 0 },
              "replay": { "type": "boolean" },
              "dlqTopic": { "type": "string", "minLength": 1 },
              "dlqSemantics": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["internalApisAuth", "signingKeysLocation", "failClosed"],
      "properties": {
        "internalApisAuth": { "type": "string", "enum": ["bearer"] },
        "signingKeysLocation": { "type": "string", "enum": ["activitypods-only"] },
        "failClosed": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "protocolStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "status"],
      "properties": {
        "enabled": { "type": "boolean" },
        "version": { "type": "string" },
        "status": { "type": "string", "enum": ["enabled", "disabled", "beta", "deprecated"] },
        "disabledReason": { "type": "string" }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "status", "dependencies", "limits"],
      "properties": {
        "id": { "type": "string", "pattern": "^(ap|at|protocol)\\.[a-z0-9.-]+$" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "status": { "type": "string", "enum": ["enabled", "disabled", "beta", "deprecated"] },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(ap|at|protocol)\\.[a-z0-9.-]+$" }
        },
        "limits": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "type": "string" },
              { "type": "integer" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        },
        "disabledReason": { "type": "string" }
      }
    },
    "override": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capabilityId", "type", "field", "value"],
      "properties": {
        "capabilityId": { "type": "string", "pattern": "^(ap|at|protocol)\\.[a-z0-9.-]+$" },
        "type": { "type": "string", "enum": ["limit", "enable", "disable"] },
        "field": { "type": "string", "minLength": 1 },
        "value": {
          "anyOf": [
            { "type": "string" },
            { "type": "integer" },
            { "type": "number" },
            { "type": "boolean" }
          ]
        }
      }
    }
  }
}

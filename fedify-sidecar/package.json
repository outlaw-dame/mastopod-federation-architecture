{
  "name": "activitypods-fedify-sidecar",
  "version": "5.0.0",
  "description": "Federation sidecar for ActivityPods with Redis Streams work queues and RedPanda event logs",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:harness": "tsx src/at-adapter/tests/local-harness.ts",
    "test:harness:phase7": "tsx src/at-adapter/tests/Phase7WriteProof.ts",
    "test:live:phase7": "tsx src/at-adapter/tests/Phase7LiveProof.ts",
    "smoke:phase7:primary": "tsx src/at-adapter/tests/Phase7PrimarySmoke.ts",
    "provision:test:fixture": "tsx scripts/provision-test-fixture.ts",
    "smoke:phase7:full": "npm run provision:test:fixture && npm run smoke:phase7:primary"
  },
  "dependencies": {
    "@fedify/fedify": "^1.4.0",
    "@hono/node-server": "^1.8.0",
    "@ipld/car": "^5.4.2",
    "@ipld/dag-cbor": "^9.2.5",
    "@opensearch-project/opensearch": "^2.6.0",
    "cborg": "^4.5.8",
    "fast-json-stable-stringify": "^2.1.0",
    "fastify": "^5.8.4",
    "hono": "^4.0.0",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "multiformats": "^13.4.2",
    "p-limit": "^5.0.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "prom-client": "^15.1.0",
    "redis": "^5.11.0",
    "ulid": "^2.3.0",
    "undici": "^6.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^8.56.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.1",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/activitypods/mastopod"
  },
  "keywords": [
    "activitypub",
    "fedify",
    "activitypods",
    "federation",
    "redpanda",
    "kafka",
    "opensearch",
    "message-queue"
  ],
  "author": "ActivityPods Team",
  "license": "AGPL-3.0"
}
